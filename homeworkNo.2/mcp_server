from mcp.server.fastmcp import FastMCP
import os

# 创建 MCP 服务器实例
mcp = FastMCP("OfficeAssistant")

@mcp.tool()
def write_file(filename: str, content: str) -> str:
    """
    创建一个新文件或覆盖现有文件。
    可用于生成待办清单、工作计划、代码片段或保存 film 摄影数据。
    """
    try:
        # 简单的安全检查：确保不会写到奇怪的系统路径
        # 你也可以指定一个专门的 workspace 文件夹
        with open(filename, "w", encoding="utf-8") as f:
            f.write(content)
        return f"✅ 成功：文件 '{filename}' 已保存。"
    except PermissionError:
        return f"❌ 错误：权限不足，无法写入 '{filename}'。"
    except Exception as e:
        return f"❌ 错误：写入失败。原因: {str(e)}"

@mcp.tool()
def read_file(filename: str) -> str:
    """读取并返回指定文件的文本内容。"""
    try:
        if not os.path.exists(filename):
            return f"❌ 错误：找不到文件 '{filename}'。"
        
        with open(filename, "r", encoding="utf-8") as f:
            content = f.read()
            # 如果文件太长，可以做个截断保护（可选）
            if len(content) > 10000:
                return content[:10000] + "\n... (内容过长已截断)"
            return content
    except Exception as e:
        return f"❌ 错误：读取失败。原因: {str(e)}"

@mcp.tool()
def get_weather(city: str = "广州") -> str:
    """
    获取指定城市的天气状况并返回出行建议。
    支持查询北京、上海、广州等城市。
    """
    # 模拟天气数据
    weather_data = {
        "北京": "晴天, 25°C, 紫外线较强，记得防晒。",
        "上海": "小雨, 20°C, 需带伞，路面湿滑。",
        "广州": "多云转晴, 28°C, 体感略显闷热，适合在大学城骑行。",
        "深圳": "阵雨, 26°C, 出门备把伞。"
    }
    
    # 模糊匹配，防止因为输入“广州市”而查不到
    matched_city = next((k for k in weather_data if k in city), None)
    
    if matched_city:
        weather = weather_data[matched_city]
        return f"【{matched_city}实况天气】: {weather}"
    else:
        return f"ℹ️ 未找到 '{city}' 的精确数据，参考周边天气：多云，24°C。"

if __name__ == "__main__":
    # 启动 MCP 服务器
    # 使用 stdio 模式，这样 client 可以通过子进程与其通信
    mcp.run()
